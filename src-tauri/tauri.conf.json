{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexBar",
  "version": "1.0.0",
  "identifier": "com.codexbar.windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CodexBar",
        "width": 400,
        "height": 600,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": true,
      "title": "CodexBar"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
